# Copy this file to .env.local for local development.
# Do not commit real secrets.

# Public URL of LetterGenerator as reachable by the ONLYOFFICE document server.
# For GitHub Codespaces, expose port 3000 publicly and paste its forwarded HTTPS URL.
LETTERGENERATOR_PUBLIC_URL=https://YOUR-LETTERGENERATOR-APP-URL

# Browser-reachable URL of ONLYOFFICE Docs.
# For GitHub Codespaces, expose port 8080 publicly and paste its forwarded HTTPS URL.
NEXT_PUBLIC_ONLYOFFICE_URL=https://YOUR-ONLYOFFICE-DOCS-URL

# URL used by Next.js when downloading saved files from ONLYOFFICE callbacks.
# For a browser-accessible deployment this may match NEXT_PUBLIC_ONLYOFFICE_URL.
ONLYOFFICE_INTERNAL_URL=https://YOUR-ONLYOFFICE-DOCS-URL

# Must exactly match JWT_SECRET in the ONLYOFFICE Docs container.
ONLYOFFICE_JWT_SECRET=replace-with-a-long-random-secret

# Existing application settings.
APP_URL=http://localhost:3000
MAX_UPLOAD_MB=25
PDF_RETENTION_HOURS=24

# Optional temporary editing storage on the Next.js server.
# LETTERGENERATOR_EDITOR_STORAGE=/tmp/lettergenerator-docx-editing
